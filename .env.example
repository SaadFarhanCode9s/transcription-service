# ============================================================
# Speech-to-Text Transcription Service — Environment Variables
# ============================================================
#
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.
#
#   cp .env.example .env
#
# All values shown here are defaults. Only override what you need.
# ============================================================

# ---- Application -----------------------------------------------
APP_NAME="Speech-to-Text Transcription Service"
APP_VERSION="1.0.0"
ENVIRONMENT=development       # development | staging | production
DEBUG=false
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ---- Server ----------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1                    # Increase for multi-core production deployments

# ---- Storage ---------------------------------------------------
UPLOAD_DIR=uploads
OUTPUT_DIR=output

# ---- File Validation -------------------------------------------
# Maximum upload size in megabytes. Also set nginx client_max_body_size.
MAX_UPLOAD_SIZE_MB=500

# ---- Audio Normalization ---------------------------------------
# These should match Whisper's training format — only change if you
# know what you are doing.
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BIT_DEPTH=pcm_s16le

# ---- Chunking --------------------------------------------------
# Long audio is split into overlapping chunks to fit Whisper's 30s window.
# See app/services/audio_chunker.py for the full explanation.
CHUNK_DURATION_SECONDS=30
CHUNK_OVERLAP_SECONDS=2

# ---- Whisper Model ---------------------------------------------
# Model size tradeoffs:
#   tiny   → fastest, least accurate, ~39M params
#   base   → good balance for demos and testing, ~74M params
#   small  → better accuracy, ~244M params
#   medium → production-grade accuracy, ~769M params
#   large-v3 → best accuracy, requires 10+ GB VRAM, ~1.5B params
WHISPER_MODEL=base

# Device for inference. Use 'cuda' if an NVIDIA GPU is available.
WHISPER_DEVICE=cpu

# Quantization for WhisperX (ignored by openai-whisper fallback).
#   int8    → fastest CPU inference (recommended for CPU deployments)
#   float16 → GPU inference
#   float32 → maximum precision, slowest
WHISPER_COMPUTE_TYPE=int8

# Force a specific language (BCP-47 code, e.g. 'en', 'fr', 'de').
# Leave empty to enable automatic language detection.
WHISPER_LANGUAGE=

# Whisper task: 'transcribe' (same language) or 'translate' (to English).
WHISPER_TASK=transcribe
